# =============================================================================
# SecureDx AI — .gitignore
# CRITICAL: Never commit PHI, secrets, or audit logs to version control
# =============================================================================

# --- Secrets & Environment ---
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
infrastructure/nginx/certs/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.prof

# --- Node / Frontend ---
node_modules/
services/frontend/dist/
services/frontend/build/
.vite/
*.tsbuildinfo

# --- ML Models (large binary files — use Git LFS or separate artifact store) ---
services/inference/models/weights/*.onnx
services/inference/models/weights/*.pt
services/inference/models/weights/*.pkl
*.onnx
*.pt

# --- Audit Logs (PHI adjacent — NEVER commit) ---
*.ndjson
audit_*.json
/var/log/securedx/

# --- Docker ---
.dockerignore

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Temporary ---
tmp/
temp/
exports/
*.tmp

# --- Database dumps (may contain PHI) ---
*.sql.gz
*.dump
pg_dump_*
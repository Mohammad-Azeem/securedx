# 74648ea49acdd7ad026b6d5a2d304e12aa45126488370cc06d7191ef142d8c17
# 1c5a59e4f91042d07af0caf3b7025cf2


# =============================================================================
# SecureDx AI — YOUR CONFIGURATION FILE
# =============================================================================
# INSTRUCTIONS:
# 1. Replace the 6 values marked ch_ below
# 2. Save this file as ".env" in the securedx/ folder
# 3. Run: make dev-up
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. CLINIC ID — Your unique clinic identifier
# ─────────────────────────────────────────────────────────────────────────────
CLINIC_ID=clinic-delhi-001
CLINIC_NAME=Clinicomine Healthcare
CLINIC_TIMEZONE=Asia/Kolkata

# ─────────────────────────────────────────────────────────────────────────────
# 2. SECRET_KEY — Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=5dde706f07da56a28cfc33e666b838cd547094de3b8088aadac2e82472501e60

# ─────────────────────────────────────────────────────────────────────────────
# 3. DB_PASSWORD — Set this to ANY strong password (your choice)
# Examples: MySecureDBPass2024! or Db$ecure#Pass123
# ─────────────────────────────────────────────────────────────────────────────
DB_PASSWORD=MySecurePass123

# ─────────────────────────────────────────────────────────────────────────────
# 4. DB_ENCRYPTION_KEY — Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────
DB_ENCRYPTION_KEY=74648ea49acdd7ad026b6d5a2d304e12aa45126488370cc06d7191ef142d8c17

# ─────────────────────────────────────────────────────────────────────────────
# 5. PSEUDONYM_SALT — Generate with: openssl rand -hex 16
# ─────────────────────────────────────────────────────────────────────────────
PSEUDONYM_SALT=1c5a59e4f91042d07af0caf3b7025cf2

# ─────────────────────────────────────────────────────────────────────────────
# 6. KEYCLOAK_ADMIN_PASSWORD — Set this to ANY strong password (your choice)
# Examples: Admin@Secure2024! or Kc$Admin#Pass123
# ─────────────────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=AdminPass456!

# =============================================================================
# EVERYTHING BELOW THIS LINE IS PRE-CONFIGURED — NO CHANGES NEEDED
# =============================================================================

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=securedx
DB_USER=securedx_app
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Keycloak
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=securedx
KEYCLOAK_CLIENT_ID=securedx-api
KEYCLOAK_CLIENT_SECRET=dev-client-secret-change-in-production
KEYCLOAK_ADMIN=admin

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
#CORS_ORIGINS=http://localhost:3000,http://localhost:8000
#CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]


# Inference
INFERENCE_SERVICE_URL=http://inference:8001
INFERENCE_TIMEOUT_SECONDS=10
MODEL_PATH=/models/securedx_v1.onnx
DIAGNOSIS_CONFIDENCE_THRESHOLD=0.70
MAX_DIFFERENTIALS=5

# Federated Learning (disabled by default for local dev)
FL_ENABLED=false
FL_COORDINATOR_URL=https://fl.example.com:9091
FL_NODE_KEY=not-needed-when-fl-disabled
DP_EPSILON=1.0
DP_DELTA=1e-5
DP_CLIP_NORM=1.0
FL_SYNC_INTERVAL_HOURS=24
FL_MIN_LOCAL_SAMPLES=50

# Audit
AUDIT_LOG_DIR=/var/log/securedx/audit
AUDIT_LOG_RETENTION_DAYS=2190
AUDIT_FHIR_EXPORT_ENABLED=true

# De-identification
DEIDENTIFICATION_METHOD=safe_harbor

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=securedx
VITE_KEYCLOAK_CLIENT_ID=securedx-frontend
VITE_FL_ENABLED=false
VITE_FEEDBACK_LOOP_ENABLED=true
VITE_AUDIT_EXPORT_ENABLED=true

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO